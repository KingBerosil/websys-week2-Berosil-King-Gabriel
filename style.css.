/* Basic CSS Improvements */
body {
  font-family: sans-serif;
   background-color: #f0f0f0; /* Light gray background */
   padding: 20px;
}
header {
   background-color: #003366; /* Dark blue */
   color: white;
   padding: 10px;
   text-align: center;
}
nav {
   margin: 20px 0;
   text-align: center;
}
section {
   background-color: white;
   padding: 15px;
   border: 1px solid #ccc;
}
